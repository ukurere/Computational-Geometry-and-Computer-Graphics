<Window x:Class="PrisonYard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orthogonal Prison Yard"
        Height="720"
        Width="1100"
        MinHeight="500"
        MinWidth="800">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="140"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,8">
            <Button Width="150"
                    Height="34"
                    Margin="0,0,10,0"
                    Content="Зчитати з файлу"
                    Click="LoadFromFile_Click"/>

            <Button Width="170"
                    Height="34"
                    Content="Намалювати з тексту"
                    Click="DrawFromText_Click"/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,0,0,8"
                Padding="10"
                BorderBrush="Black"
                BorderThickness="1"
                Background="#F5F5F5">
            <WrapPanel>
                <TextBlock Text="Кількість вершин:"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="VertexCountTextBlock"
                           Margin="6,0,20,0"
                           Text="-"/>

                <TextBlock Text="Рефлексні вершини:"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="ReflexCountTextBlock"
                           Margin="6,0,20,0"
                           Text="-"/>

                <TextBlock Text="⌊n / 4⌋:"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="GuardBoundTextBlock"
                           Margin="6,0,20,0"
                           Text="-"/>

                <TextBlock Text="Орієнтація:"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="OrientationTextBlock"
                           Margin="6,0,20,0"
                           Text="-"/>

                <TextBlock Text="Статус:"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="StatusTextBlock"
                           Margin="6,0,0,0"
                           Text="Очікування введення"/>
            </WrapPanel>
        </Border>

        <TextBox x:Name="InputTextBox"
                 Grid.Row="2"
                 Margin="0,0,0,12"
                 FontFamily="Consolas"
                 FontSize="16"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Text="8&#10;0 0&#10;0 4&#10;2 4&#10;2 6&#10;6 6&#10;6 2&#10;4 2&#10;4 0"/>

        <Border Grid.Row="3"
                BorderBrush="Black"
                BorderThickness="1"
                Background="White">
            <Canvas x:Name="DrawingCanvas"
                    Background="White"/>
        </Border>
    </Grid>
</Window>