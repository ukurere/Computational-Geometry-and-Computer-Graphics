<Window x:Class="PrisonYard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orthogonal Prison Yard"
        Height="820"
        Width="1280"
        MinHeight="600"
        MinWidth="950">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="390"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Left panel ═══ -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Width="150"
                        Height="36"
                        Margin="0,0,10,0"
                        Content="Зчитати з файлу"
                        Click="LoadFromFile_Click"/>

                <Button Width="110"
                        Height="36"
                        Content="Старт"
                        Click="BuildSteps_Click"/>
            </StackPanel>

            <!-- Status bar -->
            <Border Grid.Row="1"
                    Margin="0,0,0,10"
                    Padding="10"
                    BorderBrush="Black"
                    BorderThickness="1"
                    Background="#F6F6F6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Вершин:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" x:Name="VertexCountTextBlock" Margin="4,0,16,0" Text="-"/>
                    <TextBlock Grid.Column="2" Text="⌊n/4⌋:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="3" x:Name="GuardBoundTextBlock" Margin="4,0,16,0" Text="-"/>
                    <TextBlock Grid.Column="4" Text="Статус:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="5" x:Name="StatusTextBlock" Margin="4,0,0,0"
                               Text="Очікування введення" TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <!-- Step navigation + title + description + legend -->
            <Border Grid.Row="2"
                    Margin="0,0,0,10"
                    Padding="12"
                    BorderBrush="Black"
                    BorderThickness="1"
                    Background="#FAFAFA">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="PreviousStepButton"
                                Width="90"
                                Height="32"
                                Margin="0,0,8,0"
                                Content="Назад"
                                Click="PreviousStep_Click"/>

                        <Button x:Name="NextStepButton"
                                Width="90"
                                Height="32"
                                Margin="0,0,12,0"
                                Content="Далі"
                                Click="NextStep_Click"/>

                        <TextBlock x:Name="StepCounterTextBlock"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="Крок: - / -"/>
                    </StackPanel>

                    <TextBlock x:Name="StepTitleTextBlock"
                               Grid.Row="1"
                               Margin="0,10,0,0"
                               FontSize="16"
                               FontWeight="Bold"
                               Text="Крок алгоритму"/>

                    <TextBlock x:Name="StepDescriptionTextBlock"
                               Grid.Row="2"
                               Margin="0,6,0,6"
                               TextWrapping="Wrap"
                               Text="Натисніть «Старт», щоб перейти до покрокового перегляду."/>

                    <TextBlock x:Name="AnswerTextBlock"
                               Grid.Row="3"
                               Margin="0,0,0,10"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Text=""/>

                    <!-- Legend -->
                    <WrapPanel Grid.Row="4">
                        <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Text="Легенда:"/>
                        <TextBlock Margin="0,0,10,0" Foreground="DarkRed" FontWeight="SemiBold" Text="● Опукла"/>
                        <TextBlock Margin="0,0,0,0"  Foreground="Blue"    FontWeight="SemiBold" Text="● Рефлексна"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- Text input fills remaining space -->
            <TextBox x:Name="InputTextBox"
                     Grid.Row="3"
                     FontFamily="Consolas"
                     FontSize="15"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     Text="8&#10;0 0&#10;0 4&#10;2 4&#10;2 6&#10;6 6&#10;6 2&#10;4 2&#10;4 0"/>
        </Grid>

        <!-- ═══ Right panel: canvas ═══ -->
        <Border Grid.Column="1"
                BorderBrush="Black"
                BorderThickness="1"
                Background="White">
            <Canvas x:Name="DrawingCanvas" Background="White"/>
        </Border>
    </Grid>
</Window>
