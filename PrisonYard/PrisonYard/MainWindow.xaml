<Window x:Class="PrisonYard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orthogonal Prison Yard"
        Height="820"
        Width="1280"
        MinHeight="600"
        MinWidth="950">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="170"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,10">
            <Button Width="160"
                    Height="36"
                    Margin="0,0,10,0"
                    Content="Зчитати з файлу"
                    Click="LoadFromFile_Click"/>

            <Button Width="220"
                    Height="36"
                    Margin="0,0,10,0"
                    Content="Показати кроки алгоритму"
                    Click="BuildSteps_Click"/>

            <Button Width="190"
                    Height="36"
                    Content="Показати лише полігон"
                    Click="DrawPolygonOnly_Click"/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,0,0,10"
                Padding="10"
                BorderBrush="Black"
                BorderThickness="1"
                Background="#F6F6F6">
            <WrapPanel>
                <TextBlock Text="Кількість вершин:"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="VertexCountTextBlock"
                           Margin="6,0,20,0"
                           Text="-"/>

                <TextBlock Text="Рефлексні вершини:"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="ReflexCountTextBlock"
                           Margin="6,0,20,0"
                           Text="-"/>

                <TextBlock Text="⌊n / 4⌋:"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="GuardBoundTextBlock"
                           Margin="6,0,20,0"
                           Text="-"/>

                <TextBlock Text="Орієнтація:"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="OrientationTextBlock"
                           Margin="6,0,20,0"
                           Text="-"/>

                <TextBlock Text="Статус:"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="StatusTextBlock"
                           Margin="6,0,0,0"
                           Text="Очікування введення"/>
            </WrapPanel>
        </Border>

        <Border Grid.Row="2"
                Margin="0,0,0,10"
                Padding="12"
                BorderBrush="Black"
                BorderThickness="1"
                Background="#FAFAFA">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button x:Name="PreviousStepButton"
                            Width="110"
                            Height="34"
                            Margin="0,0,10,0"
                            Content="Назад"
                            Click="PreviousStep_Click"/>

                    <Button x:Name="NextStepButton"
                            Width="110"
                            Height="34"
                            Margin="0,0,14,0"
                            Content="Далі"
                            Click="NextStep_Click"/>

                    <TextBlock x:Name="StepCounterTextBlock"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="Крок: - / -"/>
                </StackPanel>

                <TextBlock x:Name="StepTitleTextBlock"
                           Grid.Row="1"
                           Margin="0,12,0,0"
                           FontSize="18"
                           FontWeight="Bold"
                           Text="Крок алгоритму"/>

                <Grid Grid.Row="2"
                      Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="StepDescriptionTextBlock"
                               Grid.Column="0"
                               Margin="0,0,20,0"
                               TextWrapping="Wrap"
                               Text="Натисніть «Показати кроки алгоритму», щоб перейти до покрокового перегляду."/>

                    <WrapPanel Grid.Column="1"
                               VerticalAlignment="Bottom">
                        <TextBlock Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Text="Легенда:"/>
                        <TextBlock Margin="0,0,12,0"
                                   Foreground="DarkRed"
                                   FontWeight="SemiBold"
                                   Text="● Опукла"/>
                        <TextBlock Margin="0,0,12,0"
                                   Foreground="Blue"
                                   FontWeight="SemiBold"
                                   Text="● Рефлексна"/>
                        <TextBlock Margin="0,0,12,0"
                                   Foreground="DarkGoldenrod"
                                   FontWeight="SemiBold"
                                   Text="● Поточна"/>
                        <TextBlock Margin="0,0,12,0"
                                   Foreground="IndianRed"
                                   FontWeight="SemiBold"
                                   Text="● Колір 0"/>
                        <TextBlock Margin="0,0,12,0"
                                   Foreground="SteelBlue"
                                   FontWeight="SemiBold"
                                   Text="● Колір 1"/>
                        <TextBlock Margin="0,0,12,0"
                                   Foreground="SeaGreen"
                                   FontWeight="SemiBold"
                                   Text="● Колір 2"/>
                        <TextBlock Foreground="Goldenrod"
                                   FontWeight="SemiBold"
                                   Text="● Колір 3"/>
                    </WrapPanel>
                </Grid>
            </Grid>
        </Border>

        <TextBox x:Name="InputTextBox"
                 Grid.Row="3"
                 Margin="0,0,0,12"
                 FontFamily="Consolas"
                 FontSize="16"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Text="8&#10;0 0&#10;0 4&#10;2 4&#10;2 6&#10;6 6&#10;6 2&#10;4 2&#10;4 0"/>

        <Border Grid.Row="4"
                BorderBrush="Black"
                BorderThickness="1"
                Background="White">
            <Canvas x:Name="DrawingCanvas"
                    Background="White"/>
        </Border>
    </Grid>
</Window>