<Window x:Class="PrisonYard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orthogonal Prison Yard"
        Height="760"
        Width="1200"
        MinHeight="560"
        MinWidth="900">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,8">
            <Button Width="150"
                    Height="34"
                    Margin="0,0,10,0"
                    Content="Зчитати з файлу"
                    Click="LoadFromFile_Click"/>

            <Button Width="200"
                    Height="34"
                    Margin="0,0,10,0"
                    Content="Показати кроки алгоритму"
                    Click="BuildSteps_Click"/>

            <Button Width="170"
                    Height="34"
                    Content="Показати лише полігон"
                    Click="DrawPolygonOnly_Click"/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,0,0,8"
                Padding="10"
                BorderBrush="Black"
                BorderThickness="1"
                Background="#F5F5F5">
            <WrapPanel>
                <TextBlock Text="Кількість вершин:"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="VertexCountTextBlock"
                           Margin="6,0,20,0"
                           Text="-"/>

                <TextBlock Text="Рефлексні вершини:"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="ReflexCountTextBlock"
                           Margin="6,0,20,0"
                           Text="-"/>

                <TextBlock Text="⌊n / 4⌋:"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="GuardBoundTextBlock"
                           Margin="6,0,20,0"
                           Text="-"/>

                <TextBlock Text="Орієнтація:"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="OrientationTextBlock"
                           Margin="6,0,20,0"
                           Text="-"/>

                <TextBlock Text="Статус:"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="StatusTextBlock"
                           Margin="6,0,0,0"
                           Text="Очікування введення"/>
            </WrapPanel>
        </Border>

        <Border Grid.Row="2"
                Margin="0,0,0,8"
                Padding="10"
                BorderBrush="Black"
                BorderThickness="1"
                Background="#FAFAFA">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button x:Name="PreviousStepButton"
                            Width="100"
                            Height="32"
                            Margin="0,0,8,0"
                            Content="Назад"
                            Click="PreviousStep_Click"/>

                    <Button x:Name="NextStepButton"
                            Width="100"
                            Height="32"
                            Margin="0,0,16,0"
                            Content="Далі"
                            Click="NextStep_Click"/>

                    <TextBlock x:Name="StepCounterTextBlock"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="Крок: - / -"/>
                </StackPanel>

                <TextBlock x:Name="StepTitleTextBlock"
                           Grid.Row="1"
                           Margin="0,10,0,0"
                           FontSize="18"
                           FontWeight="Bold"
                           Text="Крок алгоритму"/>

                <TextBlock x:Name="StepDescriptionTextBlock"
                           Grid.Row="2"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Text="Опис кроку"/>

                <WrapPanel Grid.Row="2"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Margin="0,8,0,0">
                    <TextBlock Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Text="Легенда:"/>
                    <TextBlock Margin="0,0,12,0"
                               Foreground="DarkRed"
                               FontWeight="SemiBold"
                               Text="● Опукла"/>
                    <TextBlock Margin="0,0,12,0"
                               Foreground="Blue"
                               FontWeight="SemiBold"
                               Text="● Рефлексна"/>
                    <TextBlock Margin="0,0,12,0"
                               Foreground="DarkGoldenrod"
                               FontWeight="SemiBold"
                               Text="● Поточна"/>
                    <TextBlock Foreground="DarkGreen"
                               FontWeight="SemiBold"
                               Text="● Камера"/>
                </WrapPanel>
            </Grid>
        </Border>

        <TextBox x:Name="InputTextBox"
                 Grid.Row="3"
                 Margin="0,0,0,12"
                 FontFamily="Consolas"
                 FontSize="16"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Text="8&#10;0 0&#10;0 4&#10;2 4&#10;2 6&#10;6 6&#10;6 2&#10;4 2&#10;4 0"/>

        <Border Grid.Row="4"
                BorderBrush="Black"
                BorderThickness="1"
                Background="White">
            <Canvas x:Name="DrawingCanvas"
                    Background="White"/>
        </Border>
    </Grid>
</Window>